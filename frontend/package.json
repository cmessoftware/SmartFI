{
  "name": "finly-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "backlog:credit-card": "node -e \"const fs=require('fs');const p=require('path').resolve('..','docs','SmartFI-V1','SmartFI_CREDIT_CARD_MODULE.backlog.json');const data=JSON.parse(fs.readFileSync(p,'utf8'));for (const item of data.items){console.log([item.id,item.type,item.priority,item.status,item.title].join(' | '));}\"",
    "backlog:credit-card:todo": "node -e \"const fs=require('fs');const p=require('path').resolve('..','docs','SmartFI-V1','SmartFI_CREDIT_CARD_MODULE.backlog.json');const data=JSON.parse(fs.readFileSync(p,'utf8'));for (const item of data.items.filter(x=>x.status!=='done')){console.log([item.id,item.type,item.priority,item.status,item.title].join(' | '));}\""
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "axios": "^1.6.0",
